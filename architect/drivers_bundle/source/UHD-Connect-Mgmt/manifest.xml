<?xml version="1.0" encoding="UTF-8"?>
<resourceDriver>
    <manifestVersion>1.4</manifestVersion>
    <version>1.2.3</version>
    <vendor>Community</vendor>
    <language>python</language>
    <interface>Configurable</interface>
    <entryPoint>uhd_connect.mgmt.driver.py</entryPoint>
    <supportCustomArguments>true</supportCustomArguments>
    <resourceProperties>
        <property optional="false">
            <name>ipAddress</name>
            <description>Management IP address of the UHD Connect appliance</description>
        </property>
        <property optional="false">
            <name>username</name>
            <description>SSH username (reserved for future SSH ops; REST is unauthenticated)</description>
        </property>
        <property optional="false">
            <name>password</name>
            <description>SSH password (reserved for future SSH ops)</description>
        </property>
        <property optional="true">
            <name>timeout</name>
            <description>REST timeout seconds (default 30)</description>
        </property>
        <property optional="true">
            <name>defaultPort</name>
            <description>Front-panel port for RS-FEC setup (default 1)</description>
        </property>
        <property optional="true">
            <name>linkSpeedGbps</name>
            <description>Layer-1 link speed in Gbps for setup (default 400)</description>
        </property>
        <property optional="true">
            <name>fecMode</name>
            <description>FEC mode for setup — reed_solomon (default)</description>
        </property>
        <property optional="true">
            <name>verifyTimeout</name>
            <description>verifyReady poll timeout seconds (default 120)</description>
        </property>
        <property optional="true">
            <name>clearConfigOnTeardown</name>
            <description>PUT empty config on teardown when no snapshot exists (default false)</description>
        </property>
    </resourceProperties>
</resourceDriver>
