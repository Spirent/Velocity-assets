                                            <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup" pathValue="{&quot;/&quot;:[switch_ports]}" pathValue.inherit="false" pathValue.sub="true">
                                                <action inherit="false">addJsonNode</action>
                                                <documentName inherit="false">response</documentName>
                                            </applicationProperties>
                                        </item>
                                        <item guid="081e1d96-b5c9-4b5c-955a-ec19b844660c" action="json" useFieldsInCommand="false">
                                            <command>
                                                <body>action=&apos;addJsonNode&apos;, editResponseStructure=false, documentName=&apos;response&apos;, pathValue=&apos;{&quot;/&quot;:[connections]}&apos;</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup" pathValue="{&quot;/&quot;:[connections]}" pathValue.inherit="false" pathValue.sub="true">
                                                <action inherit="false">addJsonNode</action>
                                                <documentName inherit="false">response</documentName>
                                            </applicationProperties>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="b2f0615c-2f37-4994-93d9-2c9941b6eb23" action="return">
                    <command>
                        <body>[response]</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
        </item>
        <item name="termOrchestratedResource">
            <steps>
                <item guid="2397bbd6-2f2d-4d8f-87ee-6c91d9435e3d" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Connect to proxmox</body>
                    </command>
                    <nestedSteps>
                        <item guid="fb4dc198-0861-4a56-91fe-4d0046741c6c" action="open" session="proxmox">
                            <command>
                                <body>project://ri_Proxmox/session_profiles/proxmox.ffsp</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.OpenStepPropertyGroup">
                                <stepProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                                <sessionProperties type="com.fnfr.svt.applications.ssh.documents.SSHProperties">
                                    <ipAddress inherit="false">[param(&apos;property_Proxmox_IP_address&apos;)]</ipAddress>
                                    <user inherit="false">[param(&apos;property_Proxmox_username&apos;)]</user>
                                    <password inherit="false" masked="false">[param(&apos;property_Proxmox_password&apos;)]</password>
                                </sessionProperties>
                                <sessionClass type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                <sessionVersion type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                            </applicationProperties>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="3dd1d5b9-3164-4eed-90a3-1f0ae157878c" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Get ReservationID as hash for VM</body>
                    </command>
                    <nestedSteps>
                        <item guid="5c9ca541-0d86-4342-9a8a-c87fac02f311" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>reservationID = velocity(&apos;reservationId&apos;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="bb80658b-a756-4309-a012-92ad6e519327" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>resourceName = tbml(&apos;property&apos;, &apos;-id&apos;,param(&apos;topologyResourceId&apos;) , &apos;name&apos;).replace(&apos; &apos;,&apos;-&apos;).replace(&apos;_&apos;,&apos;-&apos;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="1b91de6e-415d-4e68-adec-a491f5009e1b" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>VMname = resourceName+&apos;-&apos;+reservationID</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="7e066002-5027-4918-b6d8-b68aa790bc20" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Look for VMID</body>
                    </command>
                    <nestedSteps>
                        <item guid="51d3701f-416e-49e4-a336-1a8ba302d2c7" action="command" session="proxmox">
                            <command>
                                <body>qm list</body>
                            </command>
                            <postProcessing>
                                <analysisRules>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                <query sub="true">VMID_by_NAME(&quot;[VMname]&quot;)</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>vmID</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                </analysisRules>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="2ff38854-1a4f-4493-9b31-30b375565eda" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>shutdown VM</body>
                    </command>
                    <nestedSteps>
                        <item guid="51d3701f-416e-49e4-a336-1a8ba302d2c7" action="command" session="proxmox">
                            <command>
                                <body>qm shutdown [vmID]</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties">
                                <completionProperties>
                                    <maxIdleTimeAddition inherit="false">300.0</maxIdleTimeAddition>
                                </completionProperties>
                            </applicationProperties>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="4425bdb4-18eb-412f-9b00-03ac98c7fcab" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Wait for VM to start</body>
                    </command>
                    <nestedSteps>
                        <item guid="77b723cd-5fe5-4504-a643-4814139ed1c4" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>started = True</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="3db54d82-47fd-4f6b-a3db-108e1b962703" action="while" useFieldsInCommand="false">
                            <command>
                                <body>started:</body>
                            </command>
                            <nestedSteps>
                                <item guid="946a8bf5-3620-4cf1-9984-5d203cca6b0d" action="sleep">
                                    <command>
                                        <body>3</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="90cb6566-4b7a-4780-9f80-0fd84c6d318f" action="command" session="proxmox">
                                    <command>
                                        <body>qm status [vmID]</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>status()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>value == &apos;running&apos;</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="Eval">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                    <statement>started = True</statement>
                                                                </actionProperties>
                                                            </item>
                                                        </actionsWhenTrue>
                                                        <actionsWhenFalse>
                                                            <item actionId="Eval">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                    <statement>started = False</statement>
                                                                </actionProperties>
                                                            </item>
                                                        </actionsWhenFalse>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                        </analysisRules>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="921722b9-4d3a-4376-9b79-a4e9732ae58b" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>destroy VM VM</body>
                    </command>
                    <nestedSteps>
                        <item guid="51d3701f-416e-49e4-a336-1a8ba302d2c7" action="command" session="proxmox">
                            <command>
                                <body>qm destroy [vmID]</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="uuid">
                    <description>If this argument is set, use this rather than from property</description>
                </item>
            </arguments>
            <response>{}</response>
        </item>
    </procedures>
</testCase>
