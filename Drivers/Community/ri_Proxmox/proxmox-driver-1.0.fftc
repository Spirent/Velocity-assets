        <item name="initOrchestratedResource" isPublic="true">
            <steps>
                <item guid="d61f4e9a-4cc4-4be1-8936-ccd7e315ab8c" action="open" session="velocity">
                    <command>
                        <body>project://ri_Proxmox/session_profiles/velocity.ffsp</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.OpenStepPropertyGroup">
                        <stepProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        <sessionProperties type="com.fnfr.svt.adapter.automation.tools.common.documents.TransferableDocumentObject" transferableToolId="com.fnfr.itest.applications.webservices.restful" transferableType="com.fnfr.itest.applications.webservices.properties.restful.RESTfulSessionProperties" version="2" version.inherit="false"/>
                        <sessionClass type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        <sessionVersion type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                    </applicationProperties>
                </item>
                <item guid="141e1fbc-96ba-4b10-b8ba-246411de5678" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Connect to proxmox</body>
                    </command>
                    <nestedSteps>
                        <item guid="fb4dc198-0861-4a56-91fe-4d0046741c6c" action="open" session="proxmox">
                            <command>
                                <body>project://ri_Proxmox/session_profiles/proxmox.ffsp</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.OpenStepPropertyGroup">
                                <stepProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                                <sessionProperties type="com.fnfr.svt.applications.ssh.documents.SSHProperties">
                                    <ipAddress inherit="false">[param(&apos;property_Proxmox_IP_address&apos;)]</ipAddress>
                                    <user inherit="false">[param(&apos;property_Proxmox_username&apos;)]</user>
                                    <password inherit="false" masked="false">[param(&apos;property_Proxmox_password&apos;)]</password>
                                </sessionProperties>
                                <sessionClass type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                <sessionVersion type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                            </applicationProperties>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="8beac983-5511-4dd3-a9cd-a14402e4e19b" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Get ReservationID as hash for VM</body>
                    </command>
                    <nestedSteps>
                        <item guid="5c9ca541-0d86-4342-9a8a-c87fac02f311" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>reservationID = velocity(&apos;reservationId&apos;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="bb80658b-a756-4309-a012-92ad6e519327" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>resourceName = tbml(&apos;property&apos;, &apos;-id&apos;, param(&apos;topologyResourceId&apos;), &apos;name&apos;).replace(&apos; &apos;, &apos;-&apos;).replace(&apos;_&apos;, &apos;-&apos;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="b003faca-305d-4d15-92e7-eab887b99ccf" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Look for VMID</body>
                    </command>
                    <nestedSteps>
                        <item guid="68f6186e-36b7-4371-b4d7-7a326f71b37b" action="command" session="proxmox">
                            <command>
                                <body>qm list</body>
                            </command>
                            <postProcessing>
                                <analysisRules>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                <query sub="true">VMID_by_NAME(&quot;[param(&apos;property_Template&apos;)]&quot;)</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>templateID</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                </analysisRules>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                        </item>
                        <item guid="c7162fe8-3c53-40a1-9a6b-36413468ef88" action="command" session="proxmox">
                            <command>
                                <body>pvesh get /cluster/nextid</body>
                            </command>
                            <postProcessing>
                                <storeResponseAt>vmID</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="f4712a47-bb93-40e2-b312-6963fa20e8e7" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Clone VM</body>
                    </command>
                    <nestedSteps>
                        <item guid="51d3701f-416e-49e4-a336-1a8ba302d2c7" action="command" session="proxmox">
                            <command>
                                <body>qm clone [templateID] [vmID] --name [resourceName]-[reservationID]</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                        </item>
                        <item guid="8c87e282-d81c-42cb-936f-c2843a3d8d27" action="command" session="proxmox">
                            <command>
                                <body>qm start [vmID]</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                        </item>
                        <item guid="4425bdb4-18eb-412f-9b00-03ac98c7fcab" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Wait for VM to start</body>
                            </command>
                            <nestedSteps>
                                <item guid="77b723cd-5fe5-4504-a643-4814139ed1c4" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>started = False</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="3db54d82-47fd-4f6b-a3db-108e1b962703" action="while" useFieldsInCommand="false">
                                    <command>
                                        <body>not started:</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="946a8bf5-3620-4cf1-9984-5d203cca6b0d" action="sleep">
                                            <command>
                                                <body>3</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="e25b6e22-2b83-45b6-a84b-d57c6c203cd2" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>param(&apos;property_Wait_IP&apos;)==&apos;true&apos;:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="13001898-50ce-4c93-adcf-3e09ff705256" action="command" session="proxmox">
                                                    <command>
                                                        <body>qm status [vmID]</body>
                                                    </command>
                                                    <postProcessing>
                                                        <analysisRules>
                                                            <item>
                                                                <extractorInfo extractorType="query">
                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                                        <query>status()</query>
                                                                    </extractorProperties>
                                                                </extractorInfo>
                                                                <processorInfo ruleType="assert">
                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                        <expression>value == &apos;running&apos;</expression>
                                                                        <actionsWhenTrue>
                                                                            <item actionId="Eval">
                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                                    <statement>running = True</statement>
                                                                                </actionProperties>
                                                                            </item>
                                                                        </actionsWhenTrue>
                                                                        <actionsWhenFalse>
                                                                            <item actionId="Eval">
                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                                    <statement>running = False</statement>
                                                                                </actionProperties>
                                                                            </item>
                                                                        </actionsWhenFalse>
                                                                    </ruleProperties>
                                                                </processorInfo>
                                                            </item>
                                                        </analysisRules>
                                                    </postProcessing>
                                                    <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                                                </item>
                                                <item guid="d598e858-66dd-4906-b7c1-3ba72f16bdcf" action="command" session="proxmox">
                                                    <command>
                                                        <body>qm agent [vmID] network-get-interfaces</body>
                                                    </command>
                                                    <postProcessing>
                                                        <analysisRules>
                                                            <item>
                                                                <extractorInfo extractorType="query">
                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                        <query>mapped/Json/item[hardware-address!=&quot;00:00:00:00:00:00&quot;]/ip-addresses/item[ip-address-type=&quot;ipv4&quot;]/ip-address</query>
                                                                    </extractorProperties>
                                                                </extractorInfo>
                                                                <processorInfo ruleType="store">
                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                                        <storageLocation>ip</storageLocation>
                                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                                    </ruleProperties>
                                                                </processorInfo>
                                                            </item>
                                                        </analysisRules>
                                                    </postProcessing>
                                                    <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                                                </item>
                                                <item guid="4bf8094c-74cd-415c-836b-5619ac69b3e9" action="if" useFieldsInCommand="false">
                                                    <command>
                                                        <body>running and len(ip)&gt;0:</body>
                                                    </command>
                                                    <nestedSteps>
                                                        <item guid="4e052a5f-4ab0-4d37-bf80-67cbb588c860" action="eval" useFieldsInCommand="false">
                                                            <command>
                                                                <body>started = True</body>
                                                            </command>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                    </nestedSteps>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                                <item guid="03aa1557-e865-4578-a60d-a1ce88896097" action="else" useFieldsInCommand="false">
                                                    <nestedSteps>
                                                        <item guid="d9963270-3bef-4930-a1e1-a6efe5d7669c" action="eval" useFieldsInCommand="false">
                                                            <command>
                                                                <body>started = False</body>
                                                            </command>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                    </nestedSteps>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="844d63d1-e175-47fb-af13-502b8fe48267" action="else" useFieldsInCommand="false">
                                            <nestedSteps>
                                                <item guid="e79026e4-7a19-47e9-9209-66929e68c487" action="command" session="proxmox">
                                                    <command>
                                                        <body>qm status [vmID]</body>
                                                    </command>
                                                    <postProcessing>
                                                        <analysisRules>
                                                            <item>
                                                                <extractorInfo extractorType="query">
                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                                        <query>status()</query>
                                                                    </extractorProperties>
                                                                </extractorInfo>
                                                                <processorInfo ruleType="assert">
                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                        <expression>value == &apos;running&apos;</expression>
                                                                        <actionsWhenTrue>
                                                                            <item actionId="Eval">
                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                                    <statement>started = True</statement>
                                                                                </actionProperties>
                                                                            </item>
                                                                        </actionsWhenTrue>
                                                                        <actionsWhenFalse>
                                                                            <item actionId="Eval">
                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                                    <statement>started = False</statement>
                                                                                </actionProperties>
                                                                            </item>
                                                                        </actionsWhenFalse>
                                                                    </ruleProperties>
                                                                </processorInfo>
                                                            </item>
                                                        </analysisRules>
                                                    </postProcessing>
                                                    <applicationProperties type="com.fnfr.svt.editors.terminal.documents.StepDefaultProperties"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="684dbc11-2ab3-43a8-bac2-8a0831bf78e2" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Get VM properties</body>
                            </command>
                            <nestedSteps>
                                <item guid="d7565d77-de75-4489-8415-6f265f0c5f3f" action="command" session="proxmox">
                                    <command>
                                        <body>qm status [vmID] --verbose true</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>maxmem()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="store">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                        <storageLocation>maxMem</storageLocation>
                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>cpus()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="store">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                        <storageLocation>cpus</storageLocation>
                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>maxdisk()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="store">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                        <storageLocation>maxDisk</storageLocation>
                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>name()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="store">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                        <storageLocation>name</storageLocation>
                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
